# Copy this file to a new file named `.env` and fill in your real values
# from Supabase Dashboard -> Project Settings -> API.
# NEVER commit .env to git. The anon key is safe for browsers (RLS protects data),
# but keeping it in .env lets you swap projects easily.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here
